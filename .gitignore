# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# local Codex tooling/state
/.codex-tools/
/.superpowers/
/.worktrees/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.err.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
.telegram-login-state.json
.signal-hub/

# runtime caches and local snapshots
/snapshots/
*.sqlite
*.sqlite-*
*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
