TWITTER_TOKEN=
TWITTER_API_BASE=https://ai.6551.io
TWITTER_WS_URL=wss://ai.6551.io/open/twitter_wss
TWITTER_CONNECTOR_ENABLED=true
X_HYBRID_ENABLED=true
X_HYBRID_HEALTH_SCOPE=hybrid
TELEGRAM_X_SOURCE_CHANNELS=xxxx6551monitor
X_HYBRID_INTERVAL_MS=60000
X_HYBRID_CATCHUP_LOOKBACK_MS=3600000
X_HYBRID_BATCH_LIMIT=5
X_HYBRID_ENRICH_MODE=tweet-id
X_HYBRID_API_ENRICH=false
# Wait for 985 to ingest a Telegram-triggered tweet before spending 6551 points.
X_HYBRID_985_GRACE_MS=300000
MONITOR985_HYBRID_PREFLIGHT_LIMIT=100

# Single-admin web login. Use a long unique password and a random 32+ byte
# signing secret in production.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Keep true/default in production. Use false only for temporary HTTP IP access
# before a domain and HTTPS are configured.
ADMIN_COOKIE_SECURE=true

# Binance read-only CEX holdings. Create a Binance API key with account read
# access only. Do not enable trading or withdrawals for this dashboard.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_PORTFOLIO_BASE_URL=https://papi.binance.com
BINANCE_RECV_WINDOW=5000
# Optional local HTTP CONNECT proxy for regions where Binance is not directly reachable.
# Example for Clash mixed port: BINANCE_PROXY_URL=http://127.0.0.1:7890
BINANCE_PROXY_URL=

# 本地指定要盯的 X 账号，逗号分隔。即使你还没在 6551 后台加 watch，也能先在面板里显示。
TWITTER_WATCH_USERNAMES=elonmusk,VitalikButerin

# 额外要搜索的关键词，逗号分隔。
TWITTER_SEARCH_KEYWORDS=bitcoin,ethereum

# 可选调优项
TWITTER_DASHBOARD_ACCOUNTS=4
TWITTER_TWEETS_PER_ACCOUNT=3
TWITTER_DASHBOARD_SEARCH_TERMS=2
TWITTER_SEARCH_RESULTS=3
TWITTER_FEED_ITEMS=10
X_PIPELINE_FEED_ITEMS=200
X_DAILY_POINT_LIMIT=500
X_TWEET_BY_ID_POINTS=1
X_USER_TWEETS_POINTS=3

# Optional public read-only 985monitor source. When enabled, Signal Hub pulls the
# public 985monitor REST/SSE feed and filters events locally by your configured
# X accounts. It does not send your local account list, cookies, or files.
MONITOR985_ENABLED=false
MONITOR985_BASE_URL=https://985monitor.xyz
MONITOR985_FILTER_MODE=configured
MONITOR985_BOOTSTRAP_LIMIT=30
MONITOR985_CATCHUP_INTERVAL_MS=60000
MONITOR985_ACCOUNT_SYNC_INTERVAL_MS=3600000
MONITOR985_RECONNECT_MS=5000
MONITOR985_TRUTH_ACCOUNTS=realDonaldTrump
# Optional authenticated 985monitor user stream. 985's web client stores wallet
# login state in localStorage as xMonitorWalletAddress and xMonitorWalletToken.
# Prefer these two values over copying a full browser cookie.
MONITOR985_USER_ID=
MONITOR985_USER_TOKEN=
MONITOR985_WALLET_ADDRESS=
MONITOR985_AUTH_COOKIE=

# Telegram channel 监控优先使用 MTProto 用户会话
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNELS=@durov,@telegram
TELEGRAM_MESSAGES_PER_CHANNEL=3
TELEGRAM_FEED_ITEMS=12
TELEGRAM_TRANSLATE_ENABLED=true
TELEGRAM_TRANSLATE_TARGET=zh-CN

# OpenAI-compatible AI summary. The homepage supports 12h / today / 3d / 7d
# windows. The 12h view automatically regenerates every 30 minutes by default.
AI_SUMMARY_API_KEY=
AI_SUMMARY_BASE_URL=https://api.openai.com/v1
AI_SUMMARY_MODEL=gpt-4o-mini
MINIMAX_API_KEY=
# MiniMax example:
# International endpoint: AI_SUMMARY_BASE_URL=https://api.minimax.io/v1
# Mainland China endpoint: AI_SUMMARY_BASE_URL=https://api.minimaxi.com/v1
# AI_SUMMARY_MODEL=MiniMax-M2.7
AI_SUMMARY_TIME_ZONE=Asia/Shanghai
AI_SUMMARY_TIMEOUT_MS=120000
AI_SUMMARY_REFRESH_INTERVAL_MS=1800000
AI_SUMMARY_TODAY_REFRESH_INTERVAL_MS=3600000
AI_SUMMARY_3D_REFRESH_INTERVAL_MS=14400000
AI_SUMMARY_7D_REFRESH_INTERVAL_MS=86400000
# Optional: keep homepage signal summary and STOCKS research summary caches separate.
# Defaults are .signal-hub/signal-summary.sqlite and .signal-hub/stocks-summary.sqlite.
SIGNAL_SUMMARY_DB=
STOCKS_SUMMARY_DB=

# STOCKS market data. Default follows the QuantDinger-style chain:
# Finnhub when STOCKS_FINNHUB_API_KEY is configured, otherwise Yahoo, then local
# mock data. Set a provider explicitly to use massive, fmp, alpha-vantage,
# finnhub, yahoo, or mock.
STOCKS_MARKET_DATA_PROVIDER=
STOCKS_FINNHUB_API_KEY=
STOCKS_FINNHUB_MARKET_MAX_TICKERS=28
# Keep Finnhub candles off by default; some keys return 403 on /stock/candle.
STOCKS_FINNHUB_MARKET_CHART_MAX_TICKERS=0
STOCKS_FINNHUB_MARKET_REQUEST_DELAY_MS=250
STOCKS_FMP_MARKET_CHART_MAX_TICKERS=0
STOCKS_MARKET_CACHE_MS=3600000
STOCKS_MARKET_CACHE_PATH=
STOCKS_PERFORMANCE_DB=
STOCKS_ALPHA_VANTAGE_MARKET_MAX_TICKERS=1
STOCKS_ALPHA_VANTAGE_MARKET_REQUEST_DELAY_MS=1200

# STOCKS financial data. Defaults to FMP when STOCKS_FMP_API_KEY is configured,
# otherwise falls back to Yahoo, then local mock data. FMP financial endpoints
# are more expensive, so only the first high-priority tickers are queried.
STOCKS_FINANCIAL_DATA_PROVIDER=fmp
STOCKS_FMP_FINANCIAL_MAX_TICKERS=8

# STOCKS news/catalyst data. auto tries Polygon if STOCKS_POLYGON_API_KEY or
# POLYGON_API_KEY is set, then FMP if STOCKS_FMP_API_KEY or FMP_API_KEY is set,
# then Alpha Vantage if STOCKS_ALPHA_VANTAGE_API_KEY or ALPHA_VANTAGE_API_KEY is
# set, then Yahoo Finance RSS. Telegram/X local signals are supplemental only.
STOCKS_NEWS_PROVIDER=auto
STOCKS_POLYGON_API_KEY=
STOCKS_MASSIVE_API_KEY=
STOCKS_POLYGON_BASE_URL=
STOCKS_FMP_API_KEY=
STOCKS_ALPHA_VANTAGE_API_KEY=
STOCKS_INCLUDE_LOCAL_SIGNALS=true
STOCKS_NEWS_TRANSLATE_ENABLED=true
STOCKS_NEWS_TRANSLATE_TARGET=zh-CN
# Translate enough of the ranked news list to cover lower-list sectors such as storage.
STOCKS_NEWS_TRANSLATE_MAX_ITEMS=160
STOCKS_NEWS_TRANSLATE_CONCURRENCY=4
STOCKS_NEWS_TRANSLATE_TIMEOUT_MS=30000
STOCKS_NEWS_ITEMS_PER_TICKER=2
STOCKS_NEWS_READ_LIMIT=120
STOCKS_FMP_BY_TICKER=true
STOCKS_NEWS_CACHE_MS=3600000
STOCKS_NEWS_CACHE_PATH=
STOCKS_POLYGON_MAX_TICKERS=5
STOCKS_FMP_MAX_TICKERS=28
STOCKS_FMP_BATCH_SIZE=10
STOCKS_ALPHA_VANTAGE_MAX_TICKERS=1
STOCKS_ALPHA_VANTAGE_BATCH_SIZE=1
STOCKS_ALPHA_VANTAGE_LIMIT=50
STOCKS_ALPHA_VANTAGE_REQUEST_DELAY_MS=1200
STOCKS_YAHOO_NEWS_MAX_TICKERS=28

# Jin10 官方快讯接入
JIN10_SECRET_KEY=
JIN10_REST_BASE=https://open-data-api.jin10.com
JIN10_WS_URL=wss://open-api-ws.jin10.com/flash
JIN10_FLASH_CATEGORIES=1,2,5
JIN10_FLASH_ITEMS_PER_CATEGORY=4
JIN10_FEED_ITEMS=12
JIN10_HIGHLIGHT_KEYWORDS=伊朗,Iran,以色列,Israel,中东,Middle East,霍尔木兹,Hormuz,德黑兰,Tehran
JIN10_TRANSLATE_ENABLED=true
JIN10_TRANSLATE_TARGET=zh-CN

# Feishu 本机采集 + 6 小时摘要
FEISHU_LOCAL_GROUPS=交易复盘群,宏观讨论群
FEISHU_SUMMARY_HOURS=6

# 企业微信本机采集 + 6 小时摘要
WECOM_LOCAL_GROUPS=盘前群,交易执行群
WECOM_SUMMARY_HOURS=6
